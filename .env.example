# PulseFeed Configuration
# Copy this file to .env.local and fill in values

# Encryption key for API keys stored in SQLite (generate with: openssl rand -hex 32)
CONFIG_SECRET=your-secret-key-here

# MCP Service URLs (when using Docker Compose, these are set automatically)
OPENTWITTER_MCP_URL=http://localhost:8001
OPENNEWS_MCP_URL=http://localhost:8002

# Optional: Basic Auth for web UI
AUTH_PASSWORD=

# Optional: Pre-configured API keys (can also be set via Settings UI)
# LLM_API_KEY=
# TWITTER_API_KEY=
# NEWS_API_KEY=
# LARK_WEBHOOK_URL=
